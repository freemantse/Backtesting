# ============================================================================
#  Six-Cycle backtester — LOCAL SECRETS.  Do not commit this file.
#  Fill in your free API keys below (leave the others commented unless needed),
#  then run:   python -m sixcycle fetch-data --save-offline
# ============================================================================

# Tiingo — free adjusted ETF prices.  Get a key: https://www.tiingo.com  (Account -> API Token)
TIINGO_API_KEY=

# FRED — free macro data.  Get a key: https://fred.stlouisfed.org/docs/api/api_key.html
# (FRED also works WITHOUT a key via the public CSV endpoint, but a key enables
#  point-in-time ALFRED vintages — the proper fix vs AxiomQ's hindsight timeline.)
FRED_API_KEY=

# ---------------------------------------------------------------------------
# Optional networking knobs (only if you are behind a corporate proxy/firewall)
# ---------------------------------------------------------------------------
# Point to your organisation's root CA bundle if TLS verification fails:
# SIXCYCLE_CA_BUNDLE=/path/to/corporate-ca.pem
#
# Standard proxy variables are honoured automatically; set them if needed:
# HTTPS_PROXY=http://user:pass@proxy.host:port
# HTTP_PROXY=http://user:pass@proxy.host:port
#
# Last resort behind a trusted TLS-inspecting proxy (disables cert checks):
# SIXCYCLE_INSECURE_SSL=1
